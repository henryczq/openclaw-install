{
  "name": "openclaw-install",
  "description": "面向 Windows 的 OpenClaw 桌面安装与配置助手",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.js",
  "author": "振振公子 <https://github.com/henryczq>",
  "repository": {
    "type": "git",
    "url": "https://github.com/henryczq/openclaw-install"
  },
  "homepage": "https://github.com/henryczq/openclaw-install#readme",
  "bugs": {
    "url": "https://github.com/henryczq/openclaw-install/issues"
  },
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npx cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:preview": "npm run build && electron .",
    "test": "tsx tests/run-tests.ts",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:report": "tsx tests/run-tests.ts --report",
    "test:all": "tsx tests/run-tests.ts --coverage --report",
    "git:init": "git init && git add . && git commit -m \"Initial commit\"",
    "git:push": "git push -u origin main",
    "github:create": "gh repo create openclaw-install --public --source=. --remote=origin --push",
    "github:release": "npm run electron:build && node ./scripts/create-github-release.mjs",
    "upload:github": "npm run git:init && npm run github:create",
    "release": "npm version patch && git push && git push --tags"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.0",
    "antd": "^5.24.0",
    "dotenv": "^17.3.1",
    "node-fetch": "^3.3.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.50.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.0.18",
    "chai": "^6.2.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "mocha": "^11.7.5",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^8.0.0-beta.13",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "overrides": {
    "vite": "^8.0.0-beta.13"
  },
  "build": {
    "appId": "com.openclaw.installer",
    "productName": "OpenClaw安装助手",
    "directories": {
      "output": "release-build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
